🐍 1단계를 위한 간단한 파이썬 코드 (참고용)
이 코드를 실행하면 폴더 내 모든 .docx를 .txt로 한 번에 바꿔줍니다. (미리 pip install python-docx를 해두시면 됩니다.)

Python
import os
from docx import Document

source_dir = "./my_resumes"  # 워드 파일이 있는 폴더
target_dir = "./resumes_txt" # 텍스트가 저장될 폴더

if not os.path.exists(target_dir):
    os.makedirs(target_dir)

for filename in os.listdir(source_dir):
    if filename.endswith(".docx"):
        doc = Document(os.path.join(source_dir, filename))
        full_text = [para.text for para in doc.paragraphs]
        
        with open(os.path.join(target_dir, filename.replace(".docx", ".txt")), "w", encoding="utf-8") as f:
            f.write("\n".join(full_text))
